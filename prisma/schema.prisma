// ============================================================================
// Unified Property Management — MongoDB Prisma Schema
// Provider: MongoDB Atlas via `db push` (no migrations for MongoDB)
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// 1. USER
// ---------------------------------------------------------------------------
model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  phone         String?
  role          String    @default("tenant") // admin | manager | tenant

  // Subscription fields
  subscriptionTier             String?   @default("FREE") // FREE | PRO | BUSINESS
  subscriptionStatus           String?   @default("active") // active | trialing | past_due | canceled | incomplete | incomplete_expired
  stripeCustomerId             String?
  stripeSubscriptionId         String?
  subscriptionCurrentPeriodEnd DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts            Account[]
  sessions            Session[]
  tenants             Tenant[]               @relation("UserTenants")
  bookings            Booking[]
  notifications       Notification[]
  activityLogs        ActivityLog[]
  assignedMaintenance MaintenanceRequest[]   @relation("AssignedToUser")
  payments            Payment[]
  invoices            Invoice[]
  uploadedFiles       File[]                 @relation("UploadedByUser")
  properties          Property[]             @relation("UserProperties")
  razorpayOrders      RazorpayOrder[]
  webhookEvents       WebhookEvent[]
  lateFeeConfigs      LateFeeConfig[]

  @@index([role])
  @@index([subscriptionTier])
  @@index([subscriptionStatus])
  @@map("users")
}

// ---------------------------------------------------------------------------
// 1A. FILE — Uploaded files (property images, tenant docs, maintenance photos)
// ---------------------------------------------------------------------------
model File {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  url          String                            // Cloudinary URL
  publicId     String?                           // Cloudinary public_id for deletion
  filename     String                            // Original filename
  originalName String                            // Original name from user's machine
  mimeType     String                            // e.g. image/jpeg, application/pdf
  size         Int                               // File size in bytes
  width        Int?                              // Image width (if image)
  height       Int?                              // Image height (if image)
  format       String?                           // e.g. jpg, png, pdf
  resourceType String   @default("image")        // image | video | raw
  folder       String   @default("general")      // properties | tenants | maintenance | general
  entityId     String?                           // Associated entity ID (property, tenant, maintenance)
  entityType   String?                           // property | tenant | maintenance
  uploadedBy   String   @db.ObjectId             // User who uploaded
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  uploader User @relation("UploadedByUser", fields: [uploadedBy], references: [id])

  @@index([entityId, entityType])
  @@index([uploadedBy])
  @@index([folder])
  @@index([createdAt])
  @@map("files")
}

// ---------------------------------------------------------------------------
// 2. ACCOUNT (NextAuth)
// ---------------------------------------------------------------------------
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

// ---------------------------------------------------------------------------
// 3. SESSION (NextAuth)
// ---------------------------------------------------------------------------
model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// 4. VERIFICATION TOKEN (NextAuth)
// ---------------------------------------------------------------------------
model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
  @@map("verification_tokens")
}

// ---------------------------------------------------------------------------
// 5. PROPERTY
// ---------------------------------------------------------------------------
model Property {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  userId          String    @db.ObjectId
  title           String
  name            String
  description     String?
  type            String    @default("apartment") // apartment | house | condo | commercial | townhouse
  status          String    @default("vacant")     // occupied | vacant | maintenance | listed
  address         String
  city            String
  state           String
  zipCode         String
  rent            Float     @default(0)
  securityDeposit Float     @default(0)
  bedrooms        Int?
  bathrooms       Int?
  area            Float?
  squareFeet      Float?
  amenities       String[]  @default([])
  images          String[]  @default([])
  image           String?
  units           Int       @default(0)
  occupiedUnits   Int       @default(0)
  monthlyRevenue  Float     @default(0)
  yearBuilt       Int?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  tenants              Tenant[]
  maintenanceRequests  MaintenanceRequest[]
  bookings             Booking[]
  amenitiesRef         Amenity[]
  payments             Payment[]
  invoices             Invoice[]
  lateFeeConfigs        LateFeeConfig[]

  owner User @relation("UserProperties", fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([city])
  @@index([state])
  @@index([createdAt])
  @@index([status, type])
  @@map("properties")
}

// ---------------------------------------------------------------------------
// 6. TENANT
// ---------------------------------------------------------------------------
model Tenant {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  userId          String   @db.ObjectId
  propertyId      String   @db.ObjectId
  unit            String
  leaseStart      DateTime
  leaseEnd        DateTime
  rentAmount      Float
  securityDeposit Float    @default(0)
  status          String   @default("active") // active | pending | expired | evicted
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  user          User          @relation("UserTenants", fields: [userId], references: [id])
  property      Property      @relation(fields: [propertyId], references: [id])
  payments      Payment[]
  invoices      Invoice[]
  razorpayOrders RazorpayOrder[]

  @@index([userId])
  @@index([propertyId])
  @@index([status])
  @@index([leaseEnd])
  @@index([propertyId, status])
  @@map("tenants")
}

// ---------------------------------------------------------------------------
// 7. MAINTENANCE REQUEST
// ---------------------------------------------------------------------------
model MaintenanceRequest {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  propertyId   String    @db.ObjectId
  propertyName String
  unit         String
  title        String
  description  String
  category     String    @default("other") // plumbing | electrical | hvac | structural | appliance | pest | other
  priority     String    @default("medium") // low | medium | high | emergency
  status       String    @default("open")   // open | in-progress | resolved | closed
  assignedTo   String?   @db.ObjectId
  requestedBy  String
  cost         Float?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  resolvedAt   DateTime?

  // Relations
  property     Property @relation(fields: [propertyId], references: [id])
  assignedUser User?    @relation("AssignedToUser", fields: [assignedTo], references: [id])

  @@index([propertyId])
  @@index([assignedTo])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdAt])
  @@index([status, priority])
  @@map("maintenance_requests")
}

// ---------------------------------------------------------------------------
// 8. AMENITY
// ---------------------------------------------------------------------------
model Amenity {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  propertyId      String    @db.ObjectId
  name            String
  type            String    @default("other") // gym | pool | clubhouse | bbq | playground | parking | rooftop | lounge | other
  description     String?
  capacity        Int       @default(0)
  openTime        String    @default("06:00")
  closeTime       String    @default("22:00")
  requiresBooking Boolean   @default(false)
  image           String?
  status          String    @default("available") // available | maintenance | closed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  property Property  @relation(fields: [propertyId], references: [id])
  bookings Booking[]

  @@index([propertyId])
  @@index([type])
  @@index([status])
  @@map("amenities")
}

// ---------------------------------------------------------------------------
// 9. BOOKING
// ---------------------------------------------------------------------------
model Booking {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  propertyId   String    @db.ObjectId
  propertyName String
  amenityId    String    @db.ObjectId
  amenityName  String
  userId       String    @db.ObjectId
  userName     String
  date         DateTime
  startTime    String
  endTime      String
  status       String    @default("pending") // confirmed | pending | cancelled | completed
  guestCount   Int?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  property Property @relation(fields: [propertyId], references: [id])
  amenity  Amenity  @relation(fields: [amenityId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([propertyId])
  @@index([amenityId])
  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([amenityId, date])
  @@map("bookings")
}

// ---------------------------------------------------------------------------
// 10. PAYMENT
// ---------------------------------------------------------------------------
model Payment {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId            String    @db.ObjectId
  propertyId          String    @db.ObjectId
  userId              String    @db.ObjectId
  amount              Float
  type                String    @default("rent") // rent | deposit | fee | refund
  status              String    @default("pending") // pending | processing | completed | failed | refunded
  method              String    @default("bank_transfer") // bank_transfer | credit_card | cash | check | razorpay
  currency            String    @default("USD")
  dueDate             DateTime?
  paidAt              DateTime?
  description         String?
  stripeSessionId     String?
  stripePaymentIntentId String?
  receiptUrl          String?
  razorpayOrderId     String?
  razorpayPaymentId   String?
  razorpaySignature   String?
  transactionId       String?
  failureReason       String?
  refundId            String?
  refundedAt          DateTime?
  metadata            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  property Property      @relation(fields: [propertyId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  invoice  Invoice?      @relation("PaymentInvoice")
  razorpayOrder RazorpayOrder?

  @@index([tenantId])
  @@index([propertyId])
  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([stripeSessionId])
  @@index([stripePaymentIntentId])
  @@index([razorpayOrderId])
  @@index([createdAt])
  @@map("payments")
}

// ---------------------------------------------------------------------------
// 10A. INVOICE — Rent Invoicing & Collection
// ---------------------------------------------------------------------------
model Invoice {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String    @db.ObjectId
  propertyId      String    @db.ObjectId
  userId          String    @db.ObjectId
  amount          Float
  amountPaid      Float     @default(0)
  lateFee         Float     @default(0)
  lateFeeStatus   String    @default("pending") // pending | applied | waived
  invoiceNumber   String    @unique
  dueDate         DateTime
  status          String    @default("pending") // pending | processing | paid | past_due | failed | cancelled | refunded
  periodStart     DateTime
  periodEnd       DateTime
  description     String?
  paidAt          DateTime?
  paymentId       String?   @db.ObjectId @unique
  stripeSessionId String?
  receiptUrl      String?
  paymentGateway  String    @default("stripe") // stripe | razorpay
  reminderSentAt  DateTime?
  reminderCount   Int       @default(0)
  isRecurring     Boolean   @default(true)
  parentInvoiceId String?   @db.ObjectId
  razorpayOrderId String?
  retryCount      Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  tenant    Tenant        @relation(fields: [tenantId], references: [id])
  property  Property      @relation(fields: [propertyId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  payment   Payment?      @relation("PaymentInvoice", fields: [paymentId], references: [id])
  razorpayOrder RazorpayOrder?
  parentInvoice Invoice?  @relation("InvoiceRetry", fields: [parentInvoiceId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  retries   Invoice[]     @relation("InvoiceRetry")

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([dueDate])
  @@index([tenantId, status])
  @@index([propertyId, status])
  @@index([dueDate, status])
  @@index([createdAt])
  @@map("invoices")
}

// ---------------------------------------------------------------------------
// 10B. RAZORPAY ORDER — Track Razorpay orders for reconciliation
// ---------------------------------------------------------------------------
model RazorpayOrder {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  orderId         String    @unique
  amount          Float
  currency        String    @default("INR")
  receipt         String
  status          String    @default("created") // created | attempted | paid
  invoiceId       String?   @db.ObjectId @unique
  paymentId       String?   @db.ObjectId @unique
  tenantId        String   @db.ObjectId
  userId          String   @db.ObjectId
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  invoice     Invoice? @relation(fields: [invoiceId], references: [id])
  payment     Payment? @relation(fields: [paymentId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("razorpay_orders")
}

// ---------------------------------------------------------------------------
// 10C. WEBHOOK EVENT — Idempotent webhook processing
// ---------------------------------------------------------------------------
model WebhookEvent {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  eventId         String    @unique
  source          String    // stripe | razorpay
  type            String
  payload         String
  status          String    @default("pending") // pending | processed | failed
  processedAt     DateTime?
  error           String?
  userId          String?  @db.ObjectId
  createdAt       DateTime  @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@index([source, status])
  @@index([createdAt])
  @@map("webhook_events")
}

// ---------------------------------------------------------------------------
// 10D. LATE FEE CONFIG — Configurable late fee rules
// ---------------------------------------------------------------------------
model LateFeeConfig {
  id              String    @id @default(auto()) @map("_id") @db.ObjectId
  propertyId      String?   @db.ObjectId // null = global default
  userId          String   @db.ObjectId // owner/manager who configured
  type            String    @default("fixed") // fixed | percentage
  amount          Float
  gracePeriodDays Int       @default(3)
  maxFee          Float?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  property Property? @relation(fields: [propertyId], references: [id])
  user     User      @relation(fields: [userId], references: [id])

  @@index([propertyId])
  @@index([userId])
  @@index([isActive])
  @@map("late_fee_configs")
}

// ---------------------------------------------------------------------------
// 11. NOTIFICATION
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  title     String
  message   String
  type      String   @default("info") // info | warning | success | error
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
  @@map("notifications")
}

// ---------------------------------------------------------------------------
// 12. ACTIVITY LOG
// ---------------------------------------------------------------------------
model ActivityLog {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  userId     String    @db.ObjectId
  userName   String
  userAvatar String?
  action     String
  target     String
  type       String    @default("system") // booking | maintenance | property | payment | user | system
  createdAt  DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@index([type, createdAt])
  @@map("activity_logs")
}